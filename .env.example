# ── Maton API Gateway ────────────────────────────────
# 从 https://maton.ai/settings 获取
MATON_API_KEY=

# ── GA4 配置 ─────────────────────────────────────────
GA4_PROPERTY_ID=254101518

# ── GSC 配置 ─────────────────────────────────────────
GSC_SITE_URL=sc-domain:awbridal.com

# ── Supabase ─────────────────────────────────────────
# 从 Supabase 项目 Settings → API 获取
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Vercel Cron 安全令牌（自定义随机字符串） ───────────
CRON_SECRET=your-random-secret-here

# ── 竞品监控 API ──────────────────────────────────────
# Facebook Ad Library API (https://developers.facebook.com/tools/api/)
FACEBOOK_ACCESS_TOKEN=

# Trustpilot API (https://developers.trustpilot.com/)
TRUSTPILOT_API_KEY=

# SimilarWeb API (需付费订阅)
SIMILARWEB_API_KEY=
